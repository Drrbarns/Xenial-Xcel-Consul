# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Verified sender (Resend dashboard). Default uses Resend's sandbox sender for testing.
# For production, verify your domain and use e.g. "Xenium Xcel Consult <hello@yourdomain.com>"
RESEND_FROM=Xenium Xcel Consult <onboarding@resend.dev>

# Inbox for job applications (Apply Available Job). Falls back to info@xeniumxcel.com.
# Until your domain is verified in Resend, the test sender only allows delivery to certain addresses
# (often your Resend account email). Set APPLICATION_EMAIL to that address for testing.
APPLICATION_EMAIL=info@xeniumxcel.com

# Inbox for website contact form. Falls back to APPLICATION_EMAIL then info@xeniumxcel.com.
CONTACT_EMAIL=info@xeniumxcel.com

# Optional: canonical site URL (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://www.xeniumxcel.com
