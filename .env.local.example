# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# After verifying xeniumxcel.com in Resend → Domains, use a real address on that domain:
RESEND_FROM=Xenium Xcel Consult <hello@xeniumxcel.com>

# Inbox for ALL form emails. Use info@xeniumxcel.com once your domain + RESEND_FROM are verified.
# If Resend returns "only send testing emails to your own email address (...)", set FORMS_EMAIL
# to that exact address in parentheses until verification is complete — then switch back to info@.
FORMS_EMAIL=info@xeniumxcel.com

# Optional legacy overrides (only if you omit FORMS_EMAIL):
# APPLICATION_EMAIL=info@xeniumxcel.com
# CONTACT_EMAIL=info@xeniumxcel.com

# Optional: canonical site URL (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://www.xeniumxcel.com
