# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address to receive applications (defaults to info@xeniumxcel.com)
APPLICATION_EMAIL=info@xeniumxcel.com

# Canonical site URL for sitemap, robots, OG URLs, and JSON-LD (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.xeniumxcel.com
