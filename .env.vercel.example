# =============================================================================
# Xenium Xcel Consult — environment variables for Vercel (and local production)
#
# How to use on Vercel
# 1. Replace every CHANGE_ME / paste_ value below with your real secrets.
# 2. Vercel → your project → Settings → Environment Variables
#    • Use "Add" for each variable, OR paste the whole file via bulk import if your UI supports it.
# 3. Enable for: Production (required). Preview / Development (optional, same or test values).
# 4. Redeploy after saving (Deployments → … → Redeploy).
#
# Resend: domain xeniumxcel.com must stay Verified. "From" must use that domain.
# =============================================================================

# --- Canonical site URL (SEO, Open Graph, sitemap, JSON-LD) -----------------
NEXT_PUBLIC_SITE_URL=https://www.xeniumxcel.com

# --- Resend API (https://resend.com/api-keys → create key for this project) --
RESEND_API_KEY=re_CHANGE_ME_paste_full_api_key_from_resend

# Sender shown to recipients. MUST be an address on your verified domain in Resend.
# Examples that work once DNS is correct: noreply@, hello@, notifications@
RESEND_FROM="Xenium Xcel Consult <noreply@xeniumxcel.com>"

# Inbox that receives: job applications (/apply-available-job) + contact form (/contact)
FORMS_EMAIL=info@xeniumxcel.com

# --- Optional fallbacks (only if you do NOT set FORMS_EMAIL above) ----------
# APPLICATION_EMAIL=info@xeniumxcel.com
# CONTACT_EMAIL=info@xeniumxcel.com
